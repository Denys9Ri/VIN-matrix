# Django
DEBUG=False
SECRET_KEY=change-me-use-a-long-random-secret-at-least-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173
APP_VERSION=2026.06
LOG_LEVEL=INFO

# Enable only after HTTPS is configured at the proxy.
SECURE_SSL_REDIRECT=False
USE_X_FORWARDED_PROTO=False
SECURE_HSTS_SECONDS=0

# Database
USE_POSTGRES=True
DB_NAME=vin_matrix_db
DB_USER=vin_matrix
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Frontend
VITE_API_BASE_URL=http://localhost/api
# Google Analytics 4 Measurement ID, for example: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# VIN-matrix Agent / Telegram
# Create the bot through @BotFather. Keep both values only in the server-side .env.
TELEGRAM_AGENT_BOT_TOKEN=
TELEGRAM_AGENT_WEBHOOK_SECRET=

# Operations / server-side backups
# Host directory mounted into containers as /backups.
POSTGRES_BACKUP_DIR=./backups
BACKUP_DIR=/backups
BACKUP_KEEP=14
# PG_DUMP_PATH=pg_dump
